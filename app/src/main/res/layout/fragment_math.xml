<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F2F2F0">

    <!-- ── TITRE PAGE ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Table de multiplication"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#111111"
        android:fontFamily="sans-serif-black"
        android:layout_marginTop="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Entrez un nombre pour voir sa table."
        android:textSize="14sp"
        android:textColor="#999999"
        android:layout_marginBottom="20dp" />

    <!-- ── CARTE INPUT ── -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <!-- Icône -->
            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="🔢"
                android:textSize="18sp"
                android:gravity="center"
                android:background="@drawable/icon_bg_round"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nombre"
                android:textSize="14sp"
                android:textColor="#999999" />

            <EditText
                android:id="@+id/edit_nombre"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:hint="7"
                android:inputType="number"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:textColorHint="#DDDDDD"
                android:gravity="end"
                android:background="@null"
                android:imeOptions="actionDone" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── BOUTON AFFICHER ── -->
    <Button
        android:id="@+id/btn_show_table"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Afficher la table"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#111111"
        android:stateListAnimator="@null" />

</LinearLayout>