<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F2F2F0">

    <!-- ── TITRE PAGE ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Table de multiplication"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#111111"
        android:fontFamily="sans-serif-black"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Entrez un nombre pour voir sa table."
        android:textSize="13sp"
        android:textColor="#999999"
        android:layout_marginBottom="12dp" />

    <!-- ── CARTE INPUT ── -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="🔢"
                android:textSize="18sp"
                android:gravity="center"
                android:background="@drawable/icon_bg_round"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nombre"
                android:textSize="14sp"
                android:textColor="#999999" />

            <EditText
                android:id="@+id/edit_nombre"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:hint="7"
                android:inputType="number"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:textColorHint="#DDDDDD"
                android:gravity="end"
                android:background="@null"
                android:imeOptions="actionDone" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── BOUTON AFFICHER ── -->
    <Button
        android:id="@+id/btn_show_table"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Afficher la table"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#111111"
        android:stateListAnimator="@null"
        android:layout_marginBottom="10dp" />

    <!-- ── TITRE RÉSULTATS ── -->
    <TextView
        android:id="@+id/tv_table_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#111111"
        android:layout_marginBottom="6dp"
        android:visibility="gone" />

    <!-- ── LISTE RÉSULTATS ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_table"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:nestedScrollingEnabled="false"
        android:overScrollMode="never"
        android:visibility="gone" />
</LinearLayout>