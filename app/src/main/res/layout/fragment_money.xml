<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── TITRE ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Convertisseur"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:fontFamily="sans-serif-black"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Euro ↔ Ariary malgache"
            android:textSize="14sp"
            android:textColor="#999999"
            android:layout_marginBottom="20dp" />

        <!-- ── CARTE HAUT (Source) ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="0dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <!-- Icône drapeau -->
                <TextView
                    android:id="@+id/icon_top"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="🇪🇺"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:layout_marginEnd="12dp" />

                <!-- Label + Input -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Montant"
                        android:textSize="12sp"
                        android:textColor="#999999" />

                    <EditText
                        android:id="@+id/edit_top"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="0.00"
                        android:inputType="numberDecimal"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#111111"
                        android:textColorHint="#DDDDDD"
                        android:background="@null"
                        android:padding="0dp"
                        android:imeOptions="actionNext" />
                </LinearLayout>

                <!-- Spinner devise -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Devise"
                        android:textSize="12sp"
                        android:textColor="#999999"
                        android:layout_gravity="end" />

                    <Spinner
                        android:id="@+id/spinner_top"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── BOUTON SWAP ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_swap"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_swap"
                android:background="@drawable/bg_swap_button"
                android:contentDescription="Inverser les devises"
                android:padding="8dp" />
        </LinearLayout>

        <!-- ── CARTE BAS (Résultat) ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <TextView
                    android:id="@+id/icon_bottom"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="🇲🇬"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Résultat"
                        android:textSize="12sp"
                        android:textColor="#999999" />

                    <EditText
                        android:id="@+id/edit_bottom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="0.00"
                        android:inputType="numberDecimal"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#111111"
                        android:textColorHint="#DDDDDD"
                        android:background="@null"
                        android:padding="0dp"
                        android:imeOptions="actionDone" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Devise"
                        android:textSize="12sp"
                        android:textColor="#999999"
                        android:layout_gravity="end" />

                    <Spinner
                        android:id="@+id/spinner_bottom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── CARTE TAUX ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#EFEFED">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Taux utilisé"
                        android:textSize="13sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/text_rate_display"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 EUR = 4 800 Ar"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#111111" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Taux personnalisé"
                        android:textSize="12sp"
                        android:textColor="#999999" />

                    <TextView
                        android:id="@+id/text_rate_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4 800 Ar"
                        android:textSize="12sp"
                        android:textColor="#999999" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekbar_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:max="2000"
                    android:progress="800" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>