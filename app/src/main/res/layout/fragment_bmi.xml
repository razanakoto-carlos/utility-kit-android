<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F2F2F0">

    <!-- ── TITRE PAGE ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mon IMC"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#111111"
        android:fontFamily="sans-serif-black"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bonne santé, c'est simple."
        android:textSize="13sp"
        android:textColor="#999999"
        android:layout_marginBottom="12dp" />

    <!-- ── TITRE SECTION ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Vos mesures"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#111111"
        android:layout_marginBottom="8dp" />

    <!-- ── CARTE INPUTS ── -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <!-- Ligne Poids -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="⚖️"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:background="@drawable/icon_bg_round"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Poids"
                    android:textSize="14sp"
                    android:textColor="#999999" />

                <EditText
                    android:id="@+id/edit_poids"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:hint="70"
                    android:inputType="numberDecimal"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:textColorHint="#DDDDDD"
                    android:gravity="end"
                    android:background="@null"
                    android:imeOptions="actionNext" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" kg"
                    android:textSize="13sp"
                    android:textColor="#BBBBBB" />
            </LinearLayout>

            <!-- Séparateur -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#F0F0F0" />

            <!-- Ligne Taille -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="📏"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:background="@drawable/icon_bg_round"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Taille"
                    android:textSize="14sp"
                    android:textColor="#999999" />

                <EditText
                    android:id="@+id/edit_taille"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:hint="175"
                    android:inputType="numberDecimal"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:textColorHint="#DDDDDD"
                    android:gravity="end"
                    android:background="@null"
                    android:imeOptions="actionDone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" cm"
                    android:textSize="13sp"
                    android:textColor="#BBBBBB" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── BOUTON CALCULER ── -->
    <Button
        android:id="@+id/btn_calc_bmi"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Calculer mon IMC"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#111111"
        android:stateListAnimator="@null"
        android:layout_marginBottom="10dp" />

    <!-- ── CARTE RÉSULTAT ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <!-- IMC valeur -->
            <TextView
                android:id="@+id/tv_bmi_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="22.5"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:fontFamily="sans-serif-black" />

            <!-- Label IMC -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Indice de masse corporelle"
                android:textSize="12sp"
                android:textColor="#999999"
                android:layout_marginBottom="12dp" />

            <!-- Séparateur -->
            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="#111111"
                android:layout_marginBottom="12dp" />

            <!-- Catégorie -->
            <TextView
                android:id="@+id/tv_bmi_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Poids normal"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#111111" />

            <!-- Conseil -->
            <TextView
                android:id="@+id/tv_bmi_advice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Continuez comme ça !"
                android:textSize="13sp"
                android:textColor="#999999"
                android:layout_marginTop="4dp"
                android:gravity="center" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>